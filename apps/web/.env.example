# ─── Lume Chat — Frontend Environment Variables ──────────────────────────────
# Copy to apps/web/.env for local development.
# For Vercel: set these in Project Settings → Environment Variables.

# URL of the backend API (must be reachable from the user's browser)
# Local:      http://localhost:5000
# Production: https://your-api.railway.app
REACT_APP_API_URL=http://localhost:5000
