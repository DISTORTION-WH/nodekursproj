# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the deployed frontend (Vercel / custom domain)
# Leave empty for local-only development
FRONTEND_URL=https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# ─── Frontend build ────────────────────────────────────────────────────────────
# URL the browser uses to reach the API (used at React build time)
# For local Docker: http://localhost:5000
# For production:   https://your-api.railway.app
REACT_APP_API_URL=http://localhost:5000
 





# ─── Mediasoup (WebRTC SFU — group calls) ────────────────────────────────────
# MEDIASOUP_LISTEN_IP: interface the server listens on (0.0.0.0 for all)
# MEDIASOUP_ANNOUNCED_IP: public IP clients connect to
#   - Local:      127.0.0.1
#   - Production: your server's public IP (Railway: see Settings → Networking)
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
