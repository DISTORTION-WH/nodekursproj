# ─── Lume Chat — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# ─── Database ─────────────────────────────────────────────────────────────────
# Option A: individual params (local / Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_DATABASE=lume

# Option B: connection string (Railway / Supabase / Neon — overrides individual params)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the deployed frontend (Vercel / custom domain)
# Leave empty for local-only development
FRONTEND_URL=https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# ─── Frontend build ────────────────────────────────────────────────────────────
# URL the browser uses to reach the API (used at React build time)
# For local Docker: http://localhost:5000
# For production:   https://your-api.railway.app
REACT_APP_API_URL=http://localhost:5000

# ─── Cloudflare R2 (file storage) ────────────────────────────────────────────
# Create a bucket at dash.cloudflare.com → R2
MINIO_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=your_r2_access_key_id
MINIO_SECRET_KEY=your_r2_secret_access_key
MINIO_BUCKET_NAME=lume-uploads
MINIO_PUBLIC_URL=https://pub-<hash>.r2.dev

# ─── Email (EmailJS) ──────────────────────────────────────────────────────────
# Create a free account at emailjs.com
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# ─── Mediasoup (WebRTC SFU — group calls) ────────────────────────────────────
# MEDIASOUP_LISTEN_IP: interface the server listens on (0.0.0.0 for all)
# MEDIASOUP_ANNOUNCED_IP: public IP clients connect to
#   - Local:      127.0.0.1
#   - Production: your server's public IP (Railway: see Settings → Networking)
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
